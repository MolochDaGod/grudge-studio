# Database
DATABASE_URL=postgresql://user:password@localhost:5432/grudge_studio

# Server
NODE_ENV=development
PORT=5000
SESSION_SECRET=your-secret-key-change-in-production

# Google Sheets Integration (Optional)
GOOGLE_SHEET_WEAPONS=your-sheet-id-here
GOOGLE_SHEET_ARMOR=your-sheet-id-here
GOOGLE_SHEET_ITEMS=your-sheet-id-here
GOOGLE_SHEET_CRAFTING=your-sheet-id-here
GOOGLE_SHEET_ACCOUNT=your-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Puter Integration (Optional)
PUTER_CLOUD_URL=https://cloud.puter.com
PUTER_APP_ID=your-app-id
PUTER_TOKEN=your-token

# OpenAI (For AI Agents - Optional)
OPENAI_API_KEY=sk-...

# Admin
ADMIN_PASSWORD=change-this-in-production

# Authentication
BCRYPT_ROUNDS=10
AUTH_TOKEN_EXPIRY_MS=7200000
SSO_SECRET=your-sso-secret-key
SSO_TOKEN_EXPIRY_MS=300000

# Deployment (for Replit/Vercel)
REPLIT_OBJECT_STORAGE_ENABLED=false
