# ═══════════════════════════════════════════════════════
#  Grudge Studio — Production Environment Configuration
#  All services use the Grudge backend on VPS (Docker + Coolify)
#  Puter.js handles free AI + cloud storage per user (no cost to dev)
# ═══════════════════════════════════════════════════════

# ── Grudge Backend Services (VPS: Docker + Coolify) ──
GRUDGE_AUTH_URL=https://id.grudge-studio.com
GRUDGE_API_URL=https://api.grudge-studio.com
GRUDGE_ACCOUNT_URL=https://account.grudge-studio.com
GRUDGE_WS_URL=https://ws.grudge-studio.com
GRUDGE_LAUNCHER_URL=https://launcher.grudge-studio.com
GRUDGE_AI_URL=https://ai.grudge-studio.com
GRUDGE_STATUS_URL=https://status.grudge-studio.com

# ── Asset Storage (Cloudflare R2 via Worker) ──
GRUDGE_ASSETS_URL=https://assets.grudge-studio.com
GRUDGE_ASSETS_API_URL=https://assets-api.grudge-studio.com
GRUDGE_R2_WORKER_URL=https://objectstore.grudge-studio.com

# ── ObjectStore (Static game data — GitHub Pages) ──
GRUDGE_OBJECTSTORE_URL=https://molochdagod.github.io/ObjectStore

# ── Puter.js Integration (Free AI + Cloud per user) ──
# No API keys needed — Puter.js v2 SDK handles auth client-side.
# Each user's Puter account covers their own AI + storage usage.
# Just include <script src="https://js.puter.com/v2/"></script>
# Available: puter.ai.chat(), puter.ai.txt2img(), puter.fs, puter.kv
PUTER_ENABLED=true

# ── Vite Frontend Env Vars (prefixed VITE_) ──
VITE_GAME_API_URL=https://api.grudge-studio.com
VITE_AUTH_API_URL=https://id.grudge-studio.com
VITE_BACKEND_URL=https://api.grudge-studio.com
VITE_OBJECTSTORE_URL=https://molochdagod.github.io/ObjectStore
VITE_WS_URL=wss://ws.grudge-studio.com
VITE_PVP_URL=wss://ws.grudge-studio.com/pvp

# ── Server Config ──
NODE_ENV=production
PORT=5000

# ── Auth Config ──
BCRYPT_ROUNDS=10
AUTH_TOKEN_EXPIRY_MS=7200000

# ── Secrets (set these in Vercel/Coolify env, not in repo) ──
# SESSION_SECRET=<set in Vercel dashboard>
# SSO_SECRET=<set in Vercel dashboard>
# ADMIN_PASSWORD=<set in Vercel dashboard>
# OPENAI_API_KEY=<set in Coolify for AI service only>
