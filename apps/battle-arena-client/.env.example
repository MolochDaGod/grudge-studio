# ═══════════════════════════════════════════════════════
#  Battle Arena Client — Connects to Grudge game servers
# ═══════════════════════════════════════════════════════

# ── Game Server (Colyseus WebSocket) ──
VITE_SERVER_URL=wss://ws.grudge-studio.com

# ── Auth (token validation) ──
VITE_AUTH_API_URL=https://id.grudge-studio.com
VITE_GAME_API_URL=https://api.grudge-studio.com

# ── ObjectStore (static game data for items/skills) ──
VITE_OBJECTSTORE_URL=https://molochdagod.github.io/ObjectStore
