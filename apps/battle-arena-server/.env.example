# ═══════════════════════════════════════════════════════
#  Battle Arena Server — Connects to Grudge VPS MySQL
# ═══════════════════════════════════════════════════════

# ── Database (Grudge VPS MySQL via Coolify) ──
# Set real credentials in Coolify/Docker env, not committed
DB_HOST=${GRUDGE_DB_HOST}
DB_PORT=3306
DB_NAME=grudge_game
DB_USER=${GRUDGE_DB_USER}
DB_PASSWORD=${GRUDGE_DB_PASSWORD}

# ── Server ──
PORT=2567
NODE_ENV=production

# ── CORS (allowed client origins) ──
CLIENT_URL=https://grudgewarlords.com

# ── Auth (validate tokens against Grudge Identity) ──
GRUDGE_AUTH_URL=https://id.grudge-studio.com

# ── Secrets (set in Coolify env) ──
# SESSION_SECRET=<set in Coolify dashboard>
