# ═══════════════════════════════════════════════════════
#  Grudge Builder — Frontend Environment
#  Uses Grudge backend + Puter.js for free AI/storage
# ═══════════════════════════════════════════════════════

# ── Backend API ──
VITE_API_URL=https://api.grudge-studio.com
VITE_GAME_API_URL=https://api.grudge-studio.com
VITE_AUTH_API_URL=https://id.grudge-studio.com

# ── ObjectStore (static game data) ──
VITE_OBJECTSTORE_URL=https://molochdagod.github.io/ObjectStore

# ── Asset CDN (Cloudflare R2) ──
VITE_CDN_URL=https://assets.grudge-studio.com
VITE_R2_WORKER_URL=https://objectstore.grudge-studio.com

# ── Puter.js (free AI + cloud storage — no keys needed) ──
# Puter handles auth client-side via <script src="https://js.puter.com/v2/">
# Users each get their own AI quota + cloud storage through their Puter account
# APIs: puter.ai.chat(), puter.ai.txt2img(), puter.fs, puter.kv
VITE_PUTER_ENABLED=true

