{
  "name": "@grudge/combat",
  "version": "1.0.0",
  "description": "Combat engine — AI, attackers, weapons, effects, and input controls (ported from annihilatetrainer)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
