{
  "name": "@grudge/database",
  "version": "1.0.0",
  "description": "Unified database layer for Grudge Studio using Drizzle ORM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./storage": "./dist/storage.js"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.6.3",
    "@types/node": "^20.19.0"
  }
}
